{/* * ==========================================
 * VRM Quick Zoom In/Out
 * Created by Stoyan Georgiev
 * ==========================================
 */
	
  "manifest_version": 3,
  "name": "VRM Quick Zoom In/Out",
  "version": "1.0",
  "description": "Left-click to zoom into charts, right-click to go back.",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://vrm.victronenergy.com/*"],
      "js": ["content.js"]
    }
  ]
}